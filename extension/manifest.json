{
  "manifest_version": 3,
  "name": "YouTube AI Chat",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://*.youtube.com/*",
    "http://127.0.0.1:8000/*"
  ]
}